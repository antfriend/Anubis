# --- Arduino / arduino-cli / ESP32 build output ---
# Generated by `arduino-cli compile` / build.ps1 — fully reproducible from source.
build/
*/build/
**/build/
*.o
*.d
*.a
*.elf
*.map
compile_commands.json

# Compiled firmware images (regenerate with scripts\build.ps1)
*.bin
# ...but keep intentionally-published release images if added under releases/
!releases/**/*.bin

# Local arduino-cli / TFT_eSPI artifacts
User_Setup.h.orig
*.tmp

# --- OS / file-manager clutter ---
desktop.ini
Thumbs.db
ehthumbs.db
.DS_Store
.DS_Store?
$RECYCLE.BIN/

# --- Editors / IDEs ---
.vscode/
.vs/
.idea/
*.swp
*~

# --- KiCad transient files (keep sources: .kicad_pro/.kicad_sch/.kicad_pcb) ---
*-backups/
*.kicad_prl
fp-info-cache
*.lck
